@startuml Logout

header CampgroundBookingAPI Auth Sequence Diagram
footer Page %page% of %lastpage%
title "User Logout (GET)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<middleware>>\n:protect" as protectMiddleware
participant "<<controllers>>\n:auth" as controllersAuth

client->server ++:req.get('/api/v1/auth/logout')
server->protectMiddleware ++:protect (Verify JWT)
note over protectMiddleware: Check Authorization header/cookie
protectMiddleware --> server --:next (user attached to req)
server->routerAuth ++:app.use('/api/v1/auth',auth)
routerAuth -> controllersAuth ++:logout()
controllersAuth->client --: response + cookie(token='none')

@enduml
