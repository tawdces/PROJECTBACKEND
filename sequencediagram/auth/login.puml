@startuml Login

header CampgroundBookingAPI Auth Sequence Diagram
footer Page %page% of %lastpage%
title "User Login (POST)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase

client->server ++:req.post('/api/v1/auth/login')
server->routerAuth ++:app.use('/api/v1/auth',auth)
routerAuth -> controllersAuth ++:login()
controllersAuth->UsersDatabase ++: findOne({email})
UsersDatabase --> controllersAuth --: user + password
controllersAuth->modelUser ++:matchPassword(enteredPassword)
note over modelUser: bcrypt.compare with hashed password
modelUser --> controllersAuth --: isMatch (true/false)
alt isMatch == true
  controllersAuth->modelUser ++:getSignedJwtToken()
  modelUser --> controllersAuth --:token
  controllersAuth->client --:response + cookie(token)
else isMatch == false
  controllersAuth->client --:response (Invalid credentials)
end

@enduml
