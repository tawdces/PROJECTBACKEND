@startuml Register

header CampgroundBookingAPI Auth Sequence Diagram
footer Page %page% of %lastpage%
title "User Registration (POST)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase

client->server ++:req.post('/api/v1/auth/register')
server->routerAuth ++:app.use('/api/v1/auth',auth)
routerAuth -> controllersAuth ++:register()
controllersAuth->modelUser ++:create({name, telephone, email, password, role})
modelUser ->UsersDatabase ++: UserSchema
note over modelUser: Hash password with bcryptjs
UsersDatabase --> modelUser --: user
controllersAuth->modelUser ++:getSignedJwtToken()
modelUser --> controllersAuth --:token
controllersAuth->client --:response + cookie(token)

@enduml
