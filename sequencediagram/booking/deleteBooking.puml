@startuml DeleteBooking

header CampgroundBookingAPI Booking Sequence Diagram
footer Page %page% of %lastpage%
title "Delete Booking (DELETE)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<middleware>>\n:protect" as protectMiddleware
participant "<<router>>\n:bookings" as routerBookings
participant "<<controllers>>\n:bookings" as controllersBookings
participant "<<model>>\n:Booking" as modelBooking
database "<<MongoDB>>\n:bookings" as BookingsDatabase

client->server ++:req.delete('/api/v1/bookings/:id')
server->protectMiddleware ++:protect (Verify JWT)
protectMiddleware --> server --:next (user attached to req)
server->routerBookings ++:app.use('/api/v1/bookings',bookings)
routerBookings -> controllersBookings ++:deleteBooking()
controllersBookings->modelBooking ++:findById(id)
modelBooking->BookingsDatabase ++: query
BookingsDatabase --> modelBooking --: booking
controllersBookings <-- modelBooking --:booking
alt booking exists
  alt booking.user == req.user.id OR user.role == 'admin'
    controllersBookings->modelBooking ++:deleteOne()
    modelBooking->BookingsDatabase ++: delete
    BookingsDatabase --> modelBooking --: deleted
    controllersBookings <-- modelBooking --:success
    controllersBookings->client --:response (success)
  else user not authorized
    controllersBookings->client --:response (error - not authorized)
  end
else booking not exists
  controllersBookings->client --:response (error - booking not found)
end

@enduml
