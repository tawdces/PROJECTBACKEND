{
  "info": {
    "name": "Campground API Collection",
    "description": "Test requests for Campground Booking System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "register"]
        }
      }
    },
    {
      "name": "Login User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "Create Campground (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sunny Camp\",\n  \"address\": \"123 Forest Road\",\n  \"telephone\": \"123456789\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/campgrounds",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "campgrounds"]
        }
      }
    },
    {
      "name": "List Campgrounds",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/campgrounds",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "campgrounds"]
        }
      }
    },
    {
      "name": "Book Campground (User)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{user_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookingDate\": \"2026-03-10\",\n  \"nights\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/campgrounds/{{campgroundId}}/bookings",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "campgrounds", "{{campgroundId}}", "bookings"]
        }
      }
    },
    {
      "name": "View My Bookings",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{user_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/bookings",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "bookings"]
        }
      }
    },
    {
      "name": "Edit Booking",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{user_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookingDate\": \"2026-03-12\",\n  \"nights\": 3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "bookings", "{{bookingId}}"]
        }
      }
    },
    {
      "name": "Delete Booking",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{user_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "bookings", "{{bookingId}}"]
        }
      }
    },
    {
      "name": "Admin: View All Bookings",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/bookings",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "bookings"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "admin_token", "value": "" },
    { "key": "user_token", "value": "" },
    { "key": "campgroundId", "value": "" },
    { "key": "bookingId", "value": "" }
  ]
}
